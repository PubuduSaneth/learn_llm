# ─────────────────────────────────────────────────────────────────────────────
# .env — Bakery Location Intelligence Agent
# Copy this file to mcp_bakery_app/.env and fill in your values.
# Never commit this file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Google Cloud project that owns the mcp_bakery BigQuery dataset
GOOGLE_CLOUD_PROJECT=your-project-id

# GCP region (used for BigQuery job location)
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini API key — get one at https://aistudio.google.com/apikey
# Set GOOGLE_GENAI_USE_VERTEXAI=TRUE instead if using Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-gemini-api-key

# Google Maps Platform API key
# Enable: Maps JavaScript API, Places API, Directions API, Distance Matrix API
MAPS_API_KEY=your-maps-api-key
